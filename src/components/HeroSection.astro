---
import IconAppStore from './IconAppStore.astro';
import IconGooglePlay from './IconGooglePlay.astro';

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section class="hero">
  <div class="hero__grid-bg" aria-hidden="true"></div>
  <div class="hero__inner">
    <div class="hero__copy">
      <span class="eyebrow">{t['hero.eyebrow']}</span>
      <h1 class="hero__title" set:html={t['hero.title']} />
      <p class="hero__sub">{t['hero.sub']}</p>

      <div class="hero__ctas">
        <a class="store-btn" href="#" aria-label="App Store">
          <IconAppStore class="store-btn__icon" />
          <span class="store-btn__label">
            <span class="store-btn__hint">{t['store.available']}</span>
            <span class="store-btn__name">{t['store.appstore']}</span>
          </span>
        </a>
        <a class="store-btn" href="#" aria-label="Google Play">
          <IconGooglePlay class="store-btn__icon" />
          <span class="store-btn__label">
            <span class="store-btn__hint">{t['store.available']}</span>
            <span class="store-btn__name">{t['store.googleplay']}</span>
          </span>
        </a>
        <a class="btn btn--ghost" href="#">{t['hero.cta.secondary']}</a>
      </div>

      <div class="hero__meta">
        <span class="hero__meta-dot" aria-hidden="true"></span>
        <span set:html={t['hero.meta.free']} />
      </div>
    </div>

    <div class="hero__visual-wrap">
      <div class="hero__visual hero__visual--photo">
        <img
          class="hero__photo"
          src="/assets/hero-home.jpg"
          alt="Jugador y representante de club en contexto deportivo real"
          loading="eager"
          decoding="async"
        />
      </div>

      <span class="hero__chip hero__chip--left">
        <span class="hero__chip-status" aria-hidden="true"></span>
        <span>{t['hero.chip.player']}</span>
      </span>
      <span class="hero__chip hero__chip--right">
        <span class="hero__chip-avatar">CF</span>
        <span>{t['hero.chip.club']}</span>
      </span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(48px, 8vw, 96px);
    padding-bottom: clamp(48px, 8vw, 96px);
    overflow: hidden;
  }

  .hero__grid-bg {
    position: absolute;
    inset: 0;
    background-image: url('/assets/bg-net.svg');
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 30%, transparent 75%);
    opacity: 0.6;
    pointer-events: none;
    animation: hero-grid-pulse 8s ease-in-out infinite;
  }

  :root[data-theme='dark'] .hero__grid-bg {
    opacity: 0.32;
    filter: invert(1);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .hero__grid-bg {
      opacity: 0.32;
      filter: invert(1);
    }
  }

  @keyframes hero-grid-pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 0.4; }
  }

  :root[data-theme='dark'] .hero__grid-bg {
    animation: hero-grid-pulse-dark 8s ease-in-out infinite;
  }

  @keyframes hero-grid-pulse-dark {
    0%, 100% { opacity: 0.32; }
    50% { opacity: 0.2; }
  }

  .hero__inner {
    position: relative;
    max-width: var(--container, 1280px);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
  }

  @media (max-width: 920px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  .hero__copy > * + * {
    margin-top: 24px;
  }

  .hero__title {
    font-size: var(--fs-hero);
    line-height: 0.94;
    letter-spacing: -0.04em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }

  :global(.hero__title em) {
    font-style: italic;
    font-weight: 500;
    color: var(--brand-green);
    font-feature-settings: 'ss01';
  }

  .hero__sub {
    font-size: var(--fs-lead);
    color: var(--fg-muted);
    max-width: 52ch;
    line-height: 1.45;
    text-wrap: pretty;
    margin: 0;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: 13px;
    color: var(--fg-subtle);
  }

  .hero__meta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #16c447;
    box-shadow: 0 0 0 4px rgba(22, 196, 71, 0.18);
    flex-shrink: 0;
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(22, 196, 71, 0.18); }
    50% { box-shadow: 0 0 0 6px rgba(22, 196, 71, 0.08); }
  }

  .hero__visual-wrap {
    position: relative;
  }

  .hero__visual {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--r-2xl);
    overflow: hidden;
    background: var(--surface-2);
  }

  .hero__visual--photo {
    border: 1px solid var(--line);
    box-shadow: var(--shadow-lg);
  }

  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    display: block;
  }

  .hero__chip {
    position: absolute;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-pill);
    padding: 8px 14px 8px 8px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    box-shadow: var(--shadow-md);
    z-index: 2;
    white-space: nowrap;
  }

  .hero__chip--left {
    top: 56px;
    left: -28px;
    animation: floaty 6s ease-in-out infinite;
    animation-delay: 0s;
  }

  .hero__chip--right {
    bottom: 64px;
    right: -36px;
    animation: floaty 6s ease-in-out infinite;
    animation-delay: 2s;
  }

  @media (max-width: 920px) {
    .hero__chip--left { left: 8px; top: 16px; }
    .hero__chip--right { right: 8px; bottom: 16px; }
  }

  .hero__chip-status {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand-green);
    box-shadow: 0 0 0 4px rgba(1, 140, 41, 0.18);
    margin-right: 2px;
    flex: 0 0 8px;
  }

  .hero__chip-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--brand-green);
    color: white;
    display: grid;
    place-items: center;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .eyebrow {
    display: inline-block;
    font-size: var(--fs-micro, 12px);
    font-weight: 600;
    letter-spacing: var(--tracking-caps, 0.12em);
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  @keyframes floaty {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
</style>
