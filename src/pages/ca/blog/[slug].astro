---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogArticleSection from '../../../components/BlogArticleSection.astro';
import { getTranslations } from '../../../i18n/index';
import type { Lang } from '../../../i18n/index';

export const getStaticPaths = async () => {
  try {
    const res = await fetch(
      `${import.meta.env.API_BASE_URL}articles?language=ca-ES&sortField=publishedAt&sortOrder=DESC`
    );
    const data = await res.json();
    const posts = Array.isArray(data) ? data : data.items || [];
    return await Promise.all(posts.map(async (post: any) => {
      let translationSlugs: { es?: string; ca?: string; en?: string } = {};
      try {
        const tRes = await fetch(`${import.meta.env.API_BASE_URL}articles/slug/${post.slug}?language=ca-ES`);
        const tData = await tRes.json();
        if (Array.isArray(tData.translations)) {
          tData.translations.forEach((tr: { language: string; slug: string }) => {
            if (tr.language === 'es-ES') translationSlugs.es = tr.slug;
            if (tr.language === 'ca-ES') translationSlugs.ca = tr.slug;
            if (tr.language === 'en') translationSlugs.en = tr.slug;
          });
        }
      } catch { /* ignore */ }
      translationSlugs.ca = post.slug;
      return { params: { slug: post.slug }, props: { post, translationSlugs } };
    }));
  } catch {
    return [];
  }
};

const lang: Lang = 'ca';
const t = getTranslations(lang);
const { post, translationSlugs = {} } = Astro.props as { post: any; translationSlugs: { es?: string; ca?: string; en?: string } };
const translatedUrls = {
  es: translationSlugs.es ? `/blog/${translationSlugs.es}` : '/blog',
  ca: translationSlugs.ca ? `/ca/blog/${translationSlugs.ca}` : '/ca/blog',
  en: translationSlugs.en ? `/en/blog/${translationSlugs.en}` : '/en/blog',
};
---

<BaseLayout title={post.title ?? t['page.article.title']} description={post.excerpt ?? ''} lang={lang} translatedUrls={translatedUrls}>
  <BlogArticleSection t={t} lang={lang} post={post} blogBasePath="/ca/blog" />
</BaseLayout>
