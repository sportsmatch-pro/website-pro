---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogArticleSection from '../../../components/BlogArticleSection.astro';
import { getTranslations } from '../../../i18n/index';
import type { Lang } from '../../../i18n/index';

export const getStaticPaths = async () => {
  try {
    const res = await fetch(
      `${import.meta.env.API_BASE_URL}articles?language=en&sortField=publishedAt&sortOrder=DESC`
    );
    const data = await res.json();
    const posts = Array.isArray(data) ? data : data.items || [];
    return posts.map((post: any) => ({
      params: { slug: post.slug },
      props: { post },
    }));
  } catch {
    return [];
  }
};

const lang: Lang = 'en';
const t = getTranslations(lang);
const { post } = Astro.props as { post: any };
---

<BaseLayout title={post.title ?? t['page.article.title']} description={post.excerpt ?? ''} lang={lang}>
  <BlogArticleSection t={t} lang={lang} post={post} blogBasePath="/en/blog" />
</BaseLayout>
