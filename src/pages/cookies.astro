---
import BaseLayout from '../layouts/BaseLayout.astro';
import LegalPageSection from '../components/LegalPageSection.astro';
import { getTranslations } from '../i18n/index';

const lang = 'es' as const;
const t = getTranslations(lang);
---

<BaseLayout title={t['legal.cookies.title']} description={t['legal.cookies.desc']} lang={lang}>
  <LegalPageSection
    t={t}
    titleKey="legal.cookies.title"
    descKey="legal.cookies.desc"
    updatedKey="legal.cookies.updated"
    contentKey="legal.cookies.content"
  />
</BaseLayout>
