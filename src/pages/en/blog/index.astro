---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogIndexSection from '../../../components/BlogIndexSection.astro';
import { getTranslations } from '../../../i18n/index';
import type { Lang } from '../../../i18n/index';

const lang: Lang = 'en';
const t = getTranslations(lang);

type MockArticle = { slug: string; title: string; category: string; date: string; excerpt: string };

const MOCK_ARTICLES: MockArticle[] = [
  {
    slug: 'primer-articulo-deportivo',
    title: 'How to find your ideal club with SportsMatch',
    category: 'Tips',
    date: '2026-01-15',
    excerpt: 'Discover the best strategies to connect with sports clubs in your area.',
  },
  {
    slug: 'novedades-plataforma',
    title: 'Platform updates: new sports now available',
    category: 'Updates',
    date: '2026-02-10',
    excerpt: 'We are expanding our sports offering with handball, volleyball and more.',
  },
  {
    slug: 'perfil-jugador-completo',
    title: 'Create a player profile that stands out',
    category: 'Guides',
    date: '2026-03-05',
    excerpt: 'Learn how to complete your profile to increase your visibility to scouts.',
  },
];
---

<BaseLayout title={t['page.blog.title']} description={t['page.blog.desc']} lang={lang}>
  <BlogIndexSection
    t={t}
    lang={lang}
    posts={MOCK_ARTICLES}
    blogBasePath="/en/blog"
    currentPage={1}
    totalPages={1}
  />
</BaseLayout>
