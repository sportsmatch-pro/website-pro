---
import LogoIcon from "./LogoIcon.astro";
import MailIcon from "./MailIcon.astro";
import WhatsAppIcon from "./WhatsAppIcon.astro";

// Props per a l'idioma actual
export interface Props {
  currentLang?: string;
}

const { currentLang = "es-ES" } = Astro.props;

// Mapeig d'idiomes per a les URLs
const langMap = {
  "es-ES": { code: "es", name: "ES", path: "" },
  "ca-ES": { code: "ca", name: "CA", path: "/ca" },
  en: { code: "en", name: "EN", path: "/en" },
};

// Obtenir l'idioma actual
const currentLangInfo =
  langMap[currentLang as keyof typeof langMap] || langMap["es-ES"];

// Traduccions amb rutes per a cada idioma
const translations = {
  "es-ES": {
    contactUs: "Contáctanos",
    contactText:
      "Si tienes preguntas o necesitas ayuda, puedes contactarnos en:",
    legalNotice: "Aviso Legal",
    privacyPolicy: "Política de Privacidad",
    cookiesPolicy: "Política de Cookies",
    allRightsReserved: "Todos los derechos reservados.",
    routes: {
      legal: "/aviso-legal",
      privacy: "/politica-de-privacidad",
      cookies: "/cookies",
    },
  },
  "ca-ES": {
    contactUs: "Contacta'ns",
    contactText: "Si tens preguntes o necessites ajuda, pots contactar-nos a:",
    legalNotice: "Avís Legal",
    privacyPolicy: "Política de Privacitat",
    cookiesPolicy: "Política de Cookies",
    allRightsReserved: "Tots els drets reservats.",
    routes: {
      legal: "/ca/avis-legal",
      privacy: "/ca/politica-de-privacitat",
      cookies: "/ca/cookies",
    },
  },
  en: {
    contactUs: "Contact us",
    contactText:
      "If you have questions or need assistance, you can contact us at:",
    legalNotice: "Legal Notice",
    privacyPolicy: "Privacy Policy",
    cookiesPolicy: "Cookies Policy",
    allRightsReserved: "All rights reserved.",
    routes: {
      legal: "/en/legal",
      privacy: "/en/privacy-policy",
      cookies: "/en/cookies",
    },
  },
};

const t =
  translations[currentLang as keyof typeof translations] ||
  translations["es-ES"];
---

<footer class="text-white">
  <div
    class="bg-[#2e2e2e] px-[4vw] md:px-[6vw] pt-[8vw] pb-[4vw] lg:pt-[6vw] lg:pb-[2vw] text-center"
  >
    <h2
      class="text-vw-4xl md:text-vw-3xl lg:text-vw-2xl xl:text-vw-lg font-bold mb-8"
    >
      {t.contactUs}
    </h2>
    <p class="text-vw-xl md:text-vw-lg lg:text-vw-base xl:text-vw-sm mb-10">
      {t.contactText}
    </p>
    <div class="flex flex-col md:flex-row gap-[4vw] justify-center py-12">
      <a
        target="_blank"
        href="mailto:info@sportsmatch.pro"
        class="flex justify-center items-center space-x-2 border border-white/50 p-4 rounded-lg"
      >
        <MailIcon width={48} height={48} color="#82caff" />
        <span class="text-vw-xl md:text-vw-lg lg:text-vw-base xl:text-vw-sm"
          >info@sportsmatch.pro</span
        >
      </a>
      <a
        target="_blank"
        href="https://wa.me/34689472260?text=Hola%20tengo%20una%20consulta%20sobre%20la%20app"
        class="flex justify-center items-center space-x-2 border border-white/50 p-4 rounded-lg"
      >
        <WhatsAppIcon width={48} height={48} color="#25D366" />
        <span class="text-vw-xl md:text-vw-lg lg:text-vw-base xl:text-vw-sm"
          >+34 689 47 22 60</span
        >
      </a>
    </div>

    <div class="mx-auto inline-block p-4 rounded-lg">
      <LogoIcon
        width={200}
        height={90}
        color="#808080"
        secondaryColor="#ffffff"
      />
    </div>
  </div>
  <div class="bg-[#000] p-[2vw] text-center">
    <div class="flex justify-center space-x-12 text-lg mb-6">
      <a href={t.routes.legal} class="hover:underline">{t.legalNotice}</a>
      <a href={t.routes.privacy} class="hover:underline">{t.privacyPolicy}</a>
      <a href={t.routes.cookies} class="hover:underline">{t.cookiesPolicy}</a>
    </div>

    <p class="text-sm">©2024. SPORTSMATCH. {t.allRightsReserved}</p>
  </div>
</footer>
