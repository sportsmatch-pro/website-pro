---
import BaseTitle from './base/BaseTitle.astro';
import BaseText from './base/BaseText.astro';
import StatItem from './StatItem.astro';

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;

type Stat = {
  value: string;
  prefix?: string;
  counter: number;
  labelKey: string;
};

const stats: Stat[] = [
  { value: '2.000', prefix: '+', counter: 2000, labelKey: 'stats.users' },
  { value: '840',   prefix: '+', counter: 840,  labelKey: 'stats.clubs' },
  { value: '2.500', prefix: '+', counter: 2500, labelKey: 'stats.matches' },
  { value: '8',                  counter: 8,    labelKey: 'stats.sports' },
];
---

<section class="py-(--density-section) bg-bg-elev border-y border-line">
  <div class="container">

    <!-- Header -->
    <div class="flex flex-wrap justify-between items-end gap-6 mb-14">
      <div>
        <span class="eyebrow">{t['stats.eyebrow']}</span>
        <BaseTitle tag="h2" size="7xl" balance class="mt-3">
          {t['stats.title']}
        </BaseTitle>
      </div>
      <BaseText size="xl" color="muted" class="max-w-[42ch]">
        {t['stats.sub']}
      </BaseText>
    </div>

    <!-- Stats grid — gap-px + bg-line creates 1px dividers between cells -->
    <div
      data-stats-grid
      class="grid grid-cols-2 md:grid-cols-4 gap-px bg-line border border-line rounded-xl overflow-hidden"
    >
      {stats.map((stat) => (
        <StatItem
          value={stat.value}
          prefix={stat.prefix}
          counter={stat.counter}
          label={t[stat.labelKey]}
        />
      ))}
    </div>

  </div>
</section>

<script>
  const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);

  const animateCounter = (el: HTMLElement) => {
    const target = parseInt(el.dataset.counter ?? '0', 10);
    const duration = 1400;
    const start = performance.now();

    const format = (n: number) =>
      Math.round(n).toLocaleString('es-ES');

    const tick = (now: number) => {
      const elapsed = Math.min((now - start) / duration, 1);
      el.textContent = format(easeOutQuart(elapsed) * target);
      if (elapsed < 1) requestAnimationFrame(tick);
      else el.textContent = format(target);
    };

    requestAnimationFrame(tick);
  };

  const grids = document.querySelectorAll<HTMLElement>('[data-stats-grid]');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target
          .querySelectorAll<HTMLElement>('[data-counter]')
          .forEach(animateCounter);
        observer.unobserve(entry.target);
      });
    },
    { threshold: 0.3 }
  );

  grids.forEach((el) => observer.observe(el));
</script>
