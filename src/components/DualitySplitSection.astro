---
import IconArrowRight from './IconArrowRight.astro';

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section class="relative py-(--density-section) pb-0 bg-bg-elev border-y border-line overflow-hidden">

  <!-- Lead -->
  <div class="container text-center flex flex-col gap-[14px] mb-14 items-center">
    <span class="eyebrow">{t['duality.eyebrow']}</span>
    <h2 class="text-[clamp(40px,6vw,80px)] leading-[0.96] tracking-[-0.035em] font-bold m-0 max-w-[18ch] text-balance text-fg">
      {t['duality.title']}
    </h2>
  </div>

  <!-- Stage -->
  <div class="bg-black">

    <!-- Layer 1: copy + shared bg image -->
    <div class="container relative grid grid-cols-2 max-[820px]:grid-cols-1 h-[clamp(520px,44vh,720px)] max-[820px]:h-auto isolate overflow-hidden">

      <img
        class="duality-bg absolute inset-0 w-full h-full object-contain brightness-[0.55] saturate-[1.05] transition-[transform,filter] duration-slow ease-out-expo"
        src="/assets/duality-club.jpg"
        alt=""
        loading="lazy"
      />

      <!-- Left side: clubs/scouts -->
      <a class="side-link group/side relative overflow-hidden flex items-end text-white no-underline z-[2]
                transition-[flex] duration-slow ease-out-expo max-[820px]:min-h-[420px]"
         href="#"
         data-side="player"
         aria-label="Soy jugador o profesional">
        <div class="relative z-[3] p-[clamp(28px,4vw,56px)] max-w-[570px] flex flex-col gap-[14px]">
          <span class="inline-flex items-center gap-2 px-3 py-[6px]
                       bg-white/10 backdrop-blur-[8px] border border-white/[0.18] rounded-pill
                       text-[11px] font-semibold tracking-[0.12em] uppercase self-start text-white">
            {t['duality.club.tag']}
          </span>
          <h3 class="text-[clamp(28px,3.2vw,44px)] leading-[1.02] tracking-[-0.025em] font-bold m-0 text-white text-balance"
              set:html={t['duality.club.title']} />
          <p class="text-white/[0.78] text-[15px] leading-[1.55] m-0">{t['duality.club.desc']}</p>
          <ul class="bullet-list player-bullets list-none m-0 p-0 flex flex-col gap-2 text-[13.5px] text-white/[0.85] w-full">
            <li>{t['duality.club.b1']}</li>
            <li>{t['duality.club.b2']}</li>
            <li>{t['duality.club.b3']}</li>
          </ul>
          <span class="inline-flex items-center gap-[10px] mt-2 px-[18px] py-3 rounded-pill
                       text-[14px] font-bold tracking-[-0.005em] self-start no-underline
                       bg-brand-orange text-white
                       transition-[transform] duration-fast ease-snap
                       group-hover/side:-translate-y-px cta-btn">
            <span>{t['duality.club.cta']}</span>
            <IconArrowRight />
          </span>
        </div>
      </a>

      <span class="divider absolute inset-0 pointer-events-none z-[5] grid place-items-center" aria-hidden="true"></span>

      <!-- Right side: players/pros -->
      <a class="side-link group/side relative overflow-hidden flex items-end text-white no-underline z-[1]
                transition-[flex] duration-slow ease-out-expo -ml-[60px] max-[820px]:ml-0 max-[820px]:min-h-[420px]"
         href="#"
         data-side="club"
         aria-label="Soy club o scouter">
        <div class="club-copy relative z-[3] p-[clamp(28px,4vw,56px)] max-w-[470px] flex flex-col gap-[14px] ml-auto text-left items-end max-[820px]:ml-0 max-[820px]:items-start">
          <span class="inline-flex items-center gap-2 px-3 py-[6px]
                       bg-white/10 backdrop-blur-[8px] border border-white/[0.18] rounded-pill
                       text-[11px] font-semibold tracking-[0.12em] uppercase self-end text-white
                       max-[820px]:self-start">
            {t['duality.player.tag']}
          </span>
          <h3 class="text-[clamp(28px,3.2vw,44px)] leading-[1.02] tracking-[-0.025em] font-bold m-0 text-white text-balance text-right max-[820px]:text-left"
              set:html={t['duality.player.title']} />
          <p class="text-white/[0.78] text-[15px] leading-[1.55] m-0">{t['duality.player.desc']}</p>
          <ul class="bullet-list club-bullets list-none m-0 p-0 flex flex-col gap-2 text-[13.5px] text-white/[0.85] w-full">
            <li>{t['duality.player.b1']}</li>
            <li>{t['duality.player.b2']}</li>
            <li>{t['duality.player.b3']}</li>
          </ul>
          <span class="inline-flex items-center gap-[10px] mt-2 px-[18px] py-3 rounded-pill
                       text-[14px] font-bold tracking-[-0.005em] self-end no-underline
                       bg-brand-green text-white
                       transition-[transform] duration-fast ease-snap
                       group-hover/side:-translate-y-px cta-btn max-[820px]:self-start">
            <span>{t['duality.player.cta']}</span>
            <IconArrowRight />
          </span>
        </div>
      </a>
    </div>

    <!-- Layer 2: veil strips (20px) -->
    <div class="relative grid grid-cols-2 h-5 isolate overflow-hidden max-[820px]:hidden">
      <a class="group/side relative overflow-hidden" href="#" data-side="player" aria-label="Soy jugador o profesional">
        <span class="absolute inset-0 z-[1] bg-brand-orange" aria-hidden="true"></span>
      </a>
      <span class="divider absolute inset-0 pointer-events-none z-[5] grid place-items-center" aria-hidden="true"></span>
      <a class="group/side relative overflow-hidden -ml-[60px]" href="#" data-side="club" aria-label="Soy club o scouter">
        <span class="absolute inset-0 z-[1] bg-brand-green" aria-hidden="true"></span>
      </a>
    </div>
  </div>
</section>

<style>
  /* clip-path — no utility available */
  .side-link { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
  @media (max-width: 820px) { .side-link { clip-path: none !important; } }

  /* Bullet pseudo-elements — cannot be utilities */
  .bullet-list li { padding-left: 18px; position: relative; }
  .bullet-list li::before {
    content: '';
    position: absolute;
    left: 0; top: 7px;
    width: 8px; height: 8px;
    border-radius: 50%;
  }
  .player-bullets li::before {
    background: var(--brand-orange);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.18);
  }
  .club-bullets li::before {
    background: var(--brand-green);
    box-shadow: 0 0 0 3px rgba(1, 140, 41, 0.3);
  }

  /* Divider line pseudo-element */
  .divider::before {
    content: '';
    position: absolute;
    top: -10%; left: 50%;
    height: 130%; width: 30px;
    background: var(--bg-elev);
    transform: translateX(-50%);
    transform-origin: center;
  }
  @media (max-width: 820px) {
    .divider { position: relative; inset: auto; height: 60px; }
    .divider::before { height: 60px; transform: rotate(90deg); top: 0; }
  }

  /* Italic brand accent inside set:html — :global required */
  :global(.side-link[data-side='player'] h3 i) { color: var(--brand-orange); font-style: italic; }
  :global(.side-link[data-side='club'] h3 i)   { color: var(--brand-green);  font-style: italic; }

  /* Arrow icon — size + hover slide */
  :global(.cta-btn svg) { width: 16px; height: 16px; transition: transform var(--t-fast); }
  .side-link:hover :global(.cta-btn svg) { transform: translateX(4px); }

  /* Bg image hover effect — triggered by sibling side hovering */
  .side-link:hover ~ * .duality-bg,
  .side-link:hover + .duality-bg {
    transform: scale(1.04);
    filter: brightness(0.7) saturate(1.15);
  }
</style>
