---
import IconCaret from './IconCaret.astro';
import type { Lang } from '../i18n/index';

type MockArticle = {
  slug: string;
  title: string;
  category: string;
  date: string;
  excerpt: string;
};

export interface Props {
  t: Record<string, string>;
  lang: Lang;
  article: MockArticle;
  blogBasePath: string;
}

const { t, lang, article, blogBasePath } = Astro.props;
---

<article class="max-w-3xl mx-auto px-4 py-12">
  <nav data-testid="breadcrumb" aria-label="breadcrumb" class="flex items-center gap-2 text-sm text-fg-muted mb-8">
    <a href={blogBasePath} class="hover:text-fg transition-colors">
      {t['blog.article.breadcrumb.blog']}
    </a>
    <IconCaret class="-rotate-90 w-3 h-3 shrink-0" />
    <span aria-current="page" class="text-fg font-medium truncate">
      {article.title}
    </span>
  </nav>

  <header class="mb-8 flex flex-col gap-3">
    <p class="text-xs font-semibold uppercase tracking-wider text-fg-muted">
      {article.category}
    </p>
    <h1 class="text-4xl font-bold tracking-tight text-fg leading-tight">
      {article.title}
    </h1>
    <time datetime={article.date} class="text-sm text-fg-subtle">
      {article.date}
    </time>
  </header>

  <div class="article-content">
    <p>{t['blog.article.content.placeholder']}</p>
  </div>
</article>
