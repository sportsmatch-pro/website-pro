---
import IconArrowRight from './IconArrowRight.astro';

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section class="duality-split">
  <div class="duality-split__lead">
    <span class="eyebrow">{t['duality.eyebrow']}</span>
    <h2 class="duality-split__heading">{t['duality.title']}</h2>
  </div>

  <div class="duality-split__stage">
    <img
      class="duality-split__bg-img"
      src="/assets/duality-club.jpg"
      alt=""
      loading="lazy"
      aria-hidden="true"
    />

    <div class="duality-split__panels">
      <!-- Left panel: clubs/scouts -->
      <a
        class="duality-split__side duality-split__side--club"
        href="#"
        aria-label="Soy club o scouter"
      >
        <div class="duality-split__copy">
          <span class="duality-split__kicker">{t['duality.club.tag']}</span>
          <h3 class="duality-split__title" set:html={t['duality.club.title']} />
          <p class="duality-split__lede">{t['duality.club.desc']}</p>
          <ul class="duality-split__bullets">
            <li>{t['duality.club.b1']}</li>
            <li>{t['duality.club.b2']}</li>
            <li>{t['duality.club.b3']}</li>
          </ul>
          <span class="duality-split__cta">
            <span>{t['duality.club.cta']}</span>
            <IconArrowRight class="duality-split__cta-icon" />
          </span>
        </div>
      </a>

      <!-- Central divider -->
      <span class="duality-split__divider" aria-hidden="true"></span>

      <!-- Right panel: players/pros -->
      <a
        class="duality-split__side duality-split__side--player"
        href="#"
        aria-label="Soy jugador o profesional"
      >
        <div class="duality-split__copy">
          <span class="duality-split__kicker">{t['duality.player.tag']}</span>
          <h3 class="duality-split__title" set:html={t['duality.player.title']} />
          <p class="duality-split__lede">{t['duality.player.desc']}</p>
          <ul class="duality-split__bullets">
            <li>{t['duality.player.b1']}</li>
            <li>{t['duality.player.b2']}</li>
            <li>{t['duality.player.b3']}</li>
          </ul>
          <span class="duality-split__cta">
            <span>{t['duality.player.cta']}</span>
            <IconArrowRight class="duality-split__cta-icon" />
          </span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .duality-split {
    position: relative;
    padding-top: var(--density-section, 128px);
    background: var(--bg-elev);
    border-top: 1px solid var(--line);
    overflow: hidden;
  }

  .duality-split__lead {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 56px;
    align-items: center;
    max-width: var(--container, 1280px);
    margin-left: auto;
    margin-right: auto;
    padding: 0 1.5rem;
  }

  .eyebrow {
    display: inline-block;
    font-size: var(--fs-micro, 12px);
    font-weight: 600;
    letter-spacing: var(--tracking-caps, 0.12em);
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .duality-split__heading {
    font-size: clamp(40px, 6vw, 80px);
    line-height: 0.96;
    letter-spacing: -0.035em;
    font-weight: 700;
    margin: 0;
    max-width: 18ch;
    text-wrap: balance;
    color: var(--fg);
  }

  /* Stage */
  .duality-split__stage {
    position: relative;
    height: clamp(520px, 44vh, 720px);
    overflow: hidden;
    background: #000;
  }

  .duality-split__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.55) saturate(1.05);
    pointer-events: none;
  }

  /* Panels container */
  .duality-split__panels {
    position: relative;
    display: flex;
    height: 100%;
  }

  /* Side panels */
  .duality-split__side {
    position: relative;
    flex: 1 1 50%;
    display: flex;
    align-items: flex-end;
    color: #fff;
    text-decoration: none;
    overflow: hidden;
    transition: flex var(--t-slow, 480ms) var(--ease-out, cubic-bezier(0.16,1,0.3,1));
    cursor: pointer;
  }

  .duality-split__side:hover {
    flex: 1.4 1 50%;
  }

  /* Overlay tint per side */
  .duality-split__side--club::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(1, 140, 41, 0.6) 0%,
      rgba(0, 0, 0, 0.2) 60%,
      transparent 100%
    );
    z-index: 1;
    transition: opacity var(--t-slow, 480ms);
  }

  .duality-split__side--player::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(225, 69, 30, 0.6) 0%,
      rgba(0, 0, 0, 0.2) 60%,
      transparent 100%
    );
    z-index: 1;
    transition: opacity var(--t-slow, 480ms);
  }

  .duality-split__side:hover::before {
    opacity: 0.85;
  }

  /* Copy block */
  .duality-split__copy {
    position: relative;
    z-index: 3;
    padding: clamp(28px, 4vw, 56px);
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .duality-split__kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    align-self: flex-start;
    color: #fff;
  }

  .duality-split__title {
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-weight: 700;
    margin: 0;
    color: #fff;
    text-wrap: balance;
  }

  :global(.duality-split__side--club .duality-split__title i) {
    color: var(--brand-green);
    font-style: italic;
  }

  :global(.duality-split__side--player .duality-split__title i) {
    color: var(--brand-orange);
    font-style: italic;
  }

  .duality-split__lede {
    color: rgba(255, 255, 255, 0.78);
    font-size: 15px;
    line-height: 1.55;
    margin: 0;
  }

  .duality-split__bullets {
    list-style: none;
    margin: 4px 0 6px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.85);
  }

  .duality-split__bullets li {
    padding-left: 18px;
    position: relative;
  }

  .duality-split__side--club .duality-split__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand-green);
    box-shadow: 0 0 0 3px rgba(1, 140, 41, 0.3);
  }

  .duality-split__side--player .duality-split__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand-orange);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.18);
  }

  .duality-split__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
    padding: 12px 18px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.005em;
    align-self: flex-start;
    text-decoration: none;
    transition: transform var(--t-fast, 140ms) var(--ease-snap, cubic-bezier(0.4,0,0.2,1));
    color: #fff;
  }

  .duality-split__side--club .duality-split__cta {
    background: var(--brand-green);
  }

  .duality-split__side--player .duality-split__cta {
    background: var(--brand-orange);
  }

  .duality-split__side:hover .duality-split__cta {
    transform: translateY(-1px);
  }

  :global(.duality-split__cta-icon) {
    width: 16px;
    height: 16px;
    transition: transform var(--t-fast, 140ms);
  }

  .duality-split__side:hover :global(.duality-split__cta-icon) {
    transform: translateX(4px);
  }

  /* Central divider */
  .duality-split__divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 30px;
    background: var(--bg-elev);
    pointer-events: none;
    z-index: 5;
    flex-shrink: 0;
  }

  /* Mobile: stack vertically */
  @media (max-width: 820px) {
    .duality-split__stage {
      height: auto;
    }

    .duality-split__panels {
      flex-direction: column;
    }

    .duality-split__side {
      min-height: 420px;
      flex: none !important;
    }

    .duality-split__divider {
      position: relative;
      top: auto;
      bottom: auto;
      left: auto;
      transform: none;
      height: 60px;
      width: 100%;
    }
  }
</style>
