---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CookiesPage from '../../components/pages/CookiesPage.astro';
import { getTranslations } from '../../i18n/index';

const lang = 'en' as const;
const t = getTranslations(lang);
---

<BaseLayout title={t['legal.cookies.title']} description={t['legal.cookies.desc']} lang={lang}>
  <CookiesPage currentLang="en" />
</BaseLayout>
