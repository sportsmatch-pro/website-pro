---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import BlogIndexSection from '../../../../../components/BlogIndexSection.astro';
import { getTranslations } from '../../../../../i18n/index';
import type { GetStaticPaths } from 'astro';

const lang = 'en' as const;
const t = getTranslations(lang);
const blogBasePath = '/en/blog';

export const getStaticPaths = (async ({ paginate }) => {
  try {
    const [articlesRes, sportsRes] = await Promise.all([
      fetch(`${import.meta.env.API_BASE_URL}articles?language=en&sortField=publishedAt&sortOrder=DESC`),
      fetch(`${import.meta.env.API_BASE_URL}sports`),
    ]);

    const posts = await articlesRes.json();
    const postsArray = Array.isArray(posts) ? posts : posts.items || [];
    const sports = await sportsRes.json();

    const paths = sports.flatMap((sport: { id: string; key?: string; name: string }) => {
      const sportPosts = postsArray.filter((post: any) =>
        post.sports?.some((s: { id: string }) => s.id === sport.id),
      );
      if (sportPosts.length === 0) return [];
      return paginate(sportPosts, { params: { sport: sport.key ?? sport.id }, pageSize: 12 });
    });

    return paths;
  } catch {
    return [];
  }
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { sport } = Astro.params;
const translatedUrls = {
  es: `/blog/sport/${sport}`,
  ca: `/ca/blog/sport/${sport}`,
  en: `/en/blog/sport/${sport}`,
};
---

<BaseLayout title={`Blog · ${sport} · SportsMatch`} description={t['page.blog.desc']} lang={lang} translatedUrls={translatedUrls}>
  <BlogIndexSection
    t={t}
    lang={lang}
    posts={page.data}
    blogBasePath={blogBasePath}
    currentPage={page.currentPage}
    totalPages={page.lastPage}
    prevHref={page.url.prev}
    nextHref={page.url.next}
    activeSport={sport}
  />
</BaseLayout>
