---
import BaseButton from "../components/base/BaseButton.astro";
import BaseTag from "../components/base/BaseTag.astro";
import BaseTitle from "../components/base/BaseTitle.astro";
import BaseList from "../components/base/BaseList.astro";
import IconArrowRight from "./IconArrowRight.astro";
import BaseText from "./base/BaseText.astro";

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section
  class="relative pt-(--density-section) pb-0 bg-bg-elev border-y border-line overflow-hidden"
>
  <!-- Lead -->
  <div
    class="container text-center flex flex-col gap-3.5 mb-14 items-center pb-(--density-stack)"
  >
    <span class="eyebrow">{t["duality.eyebrow"]}</span>
    <BaseTitle tag="h2" size="7xl" balance>
      <span set:html={t["duality.title"]} />
    </BaseTitle>
  </div>

  <!-- Stage -->
  <div class="bg-black">
    <!-- Layer 1: copy + shared bg image -->
    <div
      class="container relative grid grid-cols-1 md:grid-cols-2 h-auto md:h-[clamp(520px,44vh,720px)] isolate overflow-hidden"
    >
      <img
        class="duality-bg absolute inset-0 w-full h-full object-cover md:object-contain brightness-[0.55] saturate-[1.05] transition-[transform,filter] duration-slow ease-out-expo"
        src="/assets/duality-club.jpg"
        alt=""
        loading="lazy"
      />

      <!-- Left side: clubs/scouts -->
      <a
        class="side-link group/side relative overflow-hidden flex items-end text-white no-underline z-[2]
                transition-[flex] duration-slow ease-out-expo md:border-b-20"
        href="#"
        data-side="player"
        aria-label="Soy jugador o profesional"
      >
        <div
          class="relative z-[3] p-[clamp(28px,4vw,56px)] max-w-[570px] flex flex-col gap-3.5 items-start"
        >
          <BaseTag size="sm">
            {t["duality.club.tag"]}
          </BaseTag>
          <BaseTitle tag="h3" size="5xl" iColor="--brand-orange" textColor="white">
            <span set:html={t["duality.club.title"]} />
          </BaseTitle>
          <BaseText size="sm" textColor="white">
            {t["duality.club.desc"]}
          </BaseText>
          <BaseList
            items={[
              t["duality.club.b1"],
              t["duality.club.b2"],
              t["duality.club.b3"],
            ]}
            bulletColor="--brand-orange"
            textColor="white"
          />
          <BaseButton
            iconRight={IconArrowRight}
            bgColor="--brand-orange"
            textColor="white"
          >
            {t["duality.club.cta"]}
          </BaseButton>
        </div>
      </a>

      <!-- Right side: players/pros -->
      <a
        class="side-link group/side relative overflow-hidden flex items-end text-white no-underline z-[1]
                transition-[flex] duration-slow ease-out-expo md:border-b-20"
        href="#"
        data-side="club"
        aria-label="Soy club o scouter"
      >
        <div
          class="club-copy relative z-[3] p-[clamp(28px,4vw,56px)] flex flex-col gap-3.5 text-left ml-0 md:ml-auto items-start md:items-end"
        >
          <BaseTag size="sm" class="md:self-end">
            {t["duality.player.tag"]}
          </BaseTag>
          <BaseTitle
            tag="h3"
            size="5xl"
            class="md:text-right"
            iColor="--brand-green"
            textColor="white"
          >
            <span set:html={t["duality.player.title"]} />
          </BaseTitle>
          <BaseText size="sm" textColor="white">
            {t["duality.player.desc"]}
          </BaseText>
          <BaseList
            items={[
              t["duality.player.b1"],
              t["duality.player.b2"],
              t["duality.player.b3"],
            ]}
            bulletColor="--brand-green"
            textColor="white"
          />
          <BaseButton
            iconRight={IconArrowRight}
            bgColor="--brand-green"
            textColor="white"
          >
            {t["duality.player.cta"]}
          </BaseButton>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .side-link[data-side="player"] {
    border-color: var(--brand-orange);
  }
  .side-link[data-side="club"] {
    border-color: var(--brand-green);
  }

  /* Bg image hover effect — triggered by sibling side hovering */
  .side-link:hover ~ * .duality-bg,
  .side-link:hover + .duality-bg {
    transform: scale(1.04);
    filter: brightness(0.7) saturate(1.15);
  }
</style>
