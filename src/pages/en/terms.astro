---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalPageSection from '../../components/LegalPageSection.astro';
import { getTranslations } from '../../i18n/index';

const lang = 'en' as const;
const t = getTranslations(lang);
---

<BaseLayout title={t['legal.terms.title']} description={t['legal.terms.desc']} lang={lang}>
  <LegalPageSection
    t={t}
    titleKey="legal.terms.title"
    descKey="legal.terms.desc"
    updatedKey="legal.terms.updated"
    contentKey="legal.terms.content"
  />
</BaseLayout>
