---
// src/components/LegalPageSection.astro

interface Props {
  t: Record<string, string>;
  titleKey: string;
  descKey: string;
  updatedKey: string;
  contentKey: string;
}

const { t, titleKey, updatedKey, contentKey } = Astro.props;
---

<section class="mx-auto max-w-3xl px-4 py-12">
  <h1 class="mb-4 text-3xl font-bold text-fg">{t[titleKey]}</h1>
  <p class="mb-8 text-sm text-fg-muted">{t[updatedKey]}</p>
  <div class="flex flex-col gap-4 leading-relaxed text-fg-muted">
    {t[contentKey]}
  </div>
</section>
