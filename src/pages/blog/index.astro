---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogIndexSection from '../../components/BlogIndexSection.astro';
import { getTranslations } from '../../i18n/index';
import type { Lang } from '../../i18n/index';

const lang: Lang = 'es';
const t = getTranslations(lang);
const blogBasePath = '/blog';

let posts: any[] = [];
try {
  const res = await fetch(`${import.meta.env.API_BASE_URL}articles?language=es-ES&sortField=publishedAt&sortOrder=DESC`);
  const data = await res.json();
  posts = Array.isArray(data) ? data : data.items || [];
} catch {
  // API not available during build
}
---

<BaseLayout title={t['page.blog.title']} description={t['page.blog.desc']} lang={lang} translatedUrls={{ es: "/blog", ca: "/ca/blog", en: "/en/blog" }}>
  <BlogIndexSection
    t={t}
    lang={lang}
    posts={posts}
    blogBasePath={blogBasePath}
  />
</BaseLayout>
