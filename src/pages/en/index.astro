---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import DualitySplitSection from '../../components/DualitySplitSection.astro';
import SportsGallerySection from '../../components/SportsGallerySection.astro';
import StatsSection from '../../components/StatsSection.astro';
import { getTranslations } from '../../i18n/index';

const lang = 'en' as const;
const t = getTranslations(lang);
---

<BaseLayout
  title={t['page.home.title'] ?? "SportsMatch — Your sports match, without middlemen"}
  description={t['page.home.desc'] ?? "The platform connecting players, professionals and sports clubs. Verified profiles, direct contact, no noise."}
  lang={lang}
>
  <HeroSection t={t} />
  <DualitySplitSection t={t} />
  <SportsGallerySection t={t} />
  <StatsSection t={t} />
</BaseLayout>
