---
import BaseButton from "./base/BaseButton.astro";
import BaseText from "./base/BaseText.astro";
import BaseTitle from "./base/BaseTitle.astro";
import StoreButtons from "./StoreButtons.astro";

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section
  class="hero-section relative pt-[clamp(48px,8vw,96px)] pb-[clamp(48px,8vw,96px)] overflow-hidden"
>
  <div
    class="relative max-w-(--container) mx-auto px-[clamp(20px,4vw,48px)] grid grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)] items-center gap-[clamp(40px,6vw,80px)] max-[920px]:grid-cols-1 max-[920px]:gap-12"
  >
    <!-- Copy -->
    <div class="flex flex-col gap-6">
      <span class="eyebrow">{t["hero.eyebrow"]}</span>

      <BaseTitle
        tag="h1"
        iColor="--brand-green"
        balance
        class="hero-title"
        style="font-size: clamp(48px, 8vw, 112px); line-height: 0.94; letter-spacing: -0.04em"
      >
        <span set:html={t["hero.title"]} />
      </BaseTitle>

      <BaseText color="muted" class="hero-sub">
        {t["hero.sub"]}
      </BaseText>

      <div class="flex flex-wrap gap-3 items-center">
        <StoreButtons t={t} ctaOrigin="hero-section" />
        <!--<BaseButton variant="outline">{t["hero.cta.secondary"]}</BaseButton>-->
      </div>

      <div class="hero-meta">
        <span class="hero-meta-dot" aria-hidden="true"></span>
        <span set:html={t["hero.meta.free"]} />
      </div>
    </div>

    <!-- Visual -->
    <div class="relative">
      <div
        class="relative aspect-[4/5] rounded-2xl overflow-hidden bg-surface-2 border border-line shadow-(--shadow-lg)"
      >
        <img
          class="w-full h-full object-cover object-[center_25%] block"
          src="/assets/hero-home.webp"
          alt="Jugador y representante de club en contexto deportivo real"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>

      <!-- Floating chip: player -->
      <span
        class="hero-chip absolute top-14 -left-7 max-[920px]:left-2 max-[920px]:top-4
                   bg-surface border border-line rounded-pill py-2 pl-2 pr-[14px]
                   inline-flex items-center gap-2 text-[13px] font-medium
                   shadow-(--shadow-md) z-[2] whitespace-nowrap"
      >
        <span
          class="w-2 h-2 rounded-full bg-brand-green shadow-[0_0_0_4px_rgba(1,140,41,0.18)] mr-0.5 shrink-0"
          aria-hidden="true"></span>
        <span>{t["hero.chip.player"]}</span>
      </span>

      <!-- Floating chip: club -->
      <span
        class="hero-chip hero-chip--delayed absolute bottom-16 -right-9 max-[920px]:right-2 max-[920px]:bottom-4
                   bg-surface border border-line rounded-pill py-2 pl-2 pr-[14px]
                   inline-flex items-center gap-2 text-[13px] font-medium
                   shadow-(--shadow-md) z-[2] whitespace-nowrap"
      >
        <span
          class="w-6 h-6 rounded-full bg-brand-green text-white grid place-items-center text-[10px] font-bold tracking-[-0.02em]"
          >CF</span
        >
        <span>{t["hero.chip.club"]}</span>
      </span>
    </div>
  </div>
</section>

<style>
  /* Keyframe animations — cannot be utility classes */
  @keyframes hero-grid-pulse {
    0%,
    100% {
      opacity: 0.6;
    }
    50% {
      opacity: 0.4;
    }
  }
  @keyframes hero-grid-pulse-dark {
    0%,
    100% {
      opacity: 0.32;
    }
    50% {
      opacity: 0.2;
    }
  }
  @keyframes floaty {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }
  @keyframes dot-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 4px rgba(22, 196, 71, 0.18);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(22, 196, 71, 0.08);
    }
  }

  .hero-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url("/assets/bg-net.svg") center / cover no-repeat;
    opacity: 0.6;
    pointer-events: none;
    mask-image: radial-gradient(
      ellipse 80% 60% at 50% 30%,
      black 30%,
      transparent 100%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 80% 60% at 50% 30%,
      black 30%,
      transparent 100%
    );
    animation: hero-grid-pulse 8s ease-in-out infinite;
  }
  :root[data-theme="dark"] .hero-section::before {
    opacity: 0.32;
    filter: invert(1);
    animation: hero-grid-pulse-dark 8s ease-in-out infinite;
  }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .hero-section::before {
      opacity: 0.32;
      filter: invert(1);
      animation: hero-grid-pulse-dark 8s ease-in-out infinite;
    }
  }

  /* italic brand color inside set:html — must use :global */
  :global(.hero-title em) {
    font-style: italic;
    font-weight: 500;
    color: var(--brand-green);
    font-feature-settings: "ss01";
  }

  .hero-meta-dot {
    animation: dot-pulse 2s ease-in-out infinite;
  }

  .hero-chip {
    animation: floaty 6s ease-in-out infinite;
  }
  .hero-chip--delayed {
    animation-delay: 2s;
  }

  .hero-sub {
    font-size: clamp(18px, 1.4vw, 22px);
    max-width: 52ch;
    line-height: 1.45;
    text-wrap: pretty;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--fg-subtle);
  }

  .hero-meta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #16c447;
    box-shadow: 0 0 0 4px rgba(22, 196, 71, 0.18);
    flex: 0 0 6px;
    animation: dot-pulse 2s ease-in-out infinite;
  }
</style>
