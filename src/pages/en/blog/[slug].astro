---
import BlogArticle, { type Post } from "../../../components/BlogArticle.astro";

export async function getStaticPaths() {
  // Cridar l'API per obtenir articles en anglès
  const res = await fetch(
    import.meta.env.API_BASE_URL + "articles?language=en",
  );
  const posts = await res.json();

  return posts.map((post: Post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props as { post: Post; allPosts: Post[] };
---

<BlogArticle post={post} allPosts={allPosts} />
