---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import DualitySplitSection from '../../components/DualitySplitSection.astro';
import SportsGallerySection from '../../components/SportsGallerySection.astro';
import StatsSection from '../../components/StatsSection.astro';
import { getTranslations } from '../../i18n/index';

const lang = 'ca' as const;
const t = getTranslations(lang);
---

<BaseLayout
  title={t['page.home.title'] ?? "SportsMatch — El teu match esportiu, sense intermediaris"}
  description={t['page.home.desc'] ?? "La plataforma que connecta jugadors, professionals i clubs esportius. Perfils verificats, contacte directe, sense soroll."}
  lang={lang}
>
  <HeroSection t={t} />
  <DualitySplitSection t={t} />
  <SportsGallerySection t={t} />
  <StatsSection t={t} />
</BaseLayout>
