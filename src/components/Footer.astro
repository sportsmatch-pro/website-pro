---
import { getTranslations, type Lang } from '../i18n/index';
import IconAppStore from './IconAppStore.astro';
import IconGooglePlay from './IconGooglePlay.astro';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

// Legal link routes
const privacyHref = lang === 'es' ? '/politica-de-privacidad' : lang === 'ca' ? '/ca/politica-de-privacitat' : '/en/privacy-policy';
const termsHref = lang === 'es' ? '/terminos' : lang === 'ca' ? '/ca/termes' : '/en/terms';
const cookiesHref = lang === 'es' ? '/cookies' : lang === 'ca' ? '/ca/cookies' : '/en/cookies';
const gdprHref = lang === 'es' ? '/gdpr' : lang === 'ca' ? '/ca/gdpr' : '/en/gdpr';

// Blog/About hrefs
const blogHref = lang === 'es' ? '/blog' : `/${lang}/blog`;
const aboutHref = lang === 'es' ? '/nosotros' : lang === 'ca' ? '/ca/nosaltres' : '/en/about';
---

<footer class="site-footer" data-testid="main-footer">
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      <!-- Brand column -->
      <div class="site-footer__brand">
        <a href={lang === 'es' ? '/' : `/${lang}`} class="site-logo" aria-label="SportsMatch">
          <img class="site-logo__img site-logo__img--dark" src="/logo-dark.svg" alt="SportsMatch" />
          <img class="site-logo__img site-logo__img--light" src="/logo-light.svg" alt="SportsMatch" />
        </a>
        <p>{t['foot.tagline']}</p>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:0.5rem;">
          <a class="store-btn" href="#" aria-label="App Store">
            <IconAppStore class="store-btn__icon" />
            <span class="store-btn__label">
              <span class="store-btn__hint">{t['store.available']}</span>
              <span class="store-btn__name">{t['store.appstore']}</span>
            </span>
          </a>
          <a class="store-btn" href="#" aria-label="Google Play">
            <IconGooglePlay class="store-btn__icon" />
            <span class="store-btn__label">
              <span class="store-btn__hint">{t['store.available']}</span>
              <span class="store-btn__name">{t['store.googleplay']}</span>
            </span>
          </a>
        </div>
      </div>

      <!-- Producto column -->
      <div>
        <p class="footer-col__title">{t['foot.product']}</p>
        <ul class="footer-col__list">
          <li><a href="#">{t['foot.product.clubs']}</a></li>
          <li><a href="#">{t['foot.product.players']}</a></li>
          <li><a href="#">{t['foot.product.pros']}</a></li>
          <li><a href="#">{t['foot.product.sports']}</a></li>
          <li><a href="#">{t['foot.product.pricing']}</a></li>
        </ul>
      </div>

      <!-- Empresa column -->
      <div>
        <p class="footer-col__title">{t['foot.company']}</p>
        <ul class="footer-col__list">
          <li><a href={aboutHref}>{t['foot.company.about']}</a></li>
          <li><a href={blogHref}>{t['foot.company.blog']}</a></li>
          <li><a href="#">{t['foot.company.press']}</a></li>
          <li><a href="#">{t['foot.company.contact']}</a></li>
        </ul>
      </div>

      <!-- Comunidad column -->
      <div>
        <p class="footer-col__title">{t['foot.community']}</p>
        <ul class="footer-col__list">
          <li><a href="#" target="_blank" rel="noopener noreferrer">{t['foot.community.instagram']}</a></li>
          <li><a href="#" target="_blank" rel="noopener noreferrer">{t['foot.community.tiktok']}</a></li>
          <li><a href="#" target="_blank" rel="noopener noreferrer">{t['foot.community.linkedin']}</a></li>
          <li><a href="#" target="_blank" rel="noopener noreferrer">{t['foot.community.twitter']}</a></li>
        </ul>
      </div>

      <!-- Legal column -->
      <div>
        <p class="footer-col__title">{t['foot.legal']}</p>
        <ul class="footer-col__list">
          <li><a href={privacyHref}>{t['foot.privacy']}</a></li>
          <li><a href={termsHref}>{t['foot.terms']}</a></li>
          <li><a href={cookiesHref}>{t['foot.cookies']}</a></li>
          <li><a href={gdprHref}>{t['foot.gdpr']}</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="site-footer__bottom">
      <span>{t['foot.copy']}</span>
      <div class="site-footer__bottom-links">
        <a href="mailto:info@sportsmatch.pro">info@sportsmatch.pro</a>
        <a href="tel:+34623757950">+34 623 75 79 50</a>
      </div>
    </div>
  </div>
</footer>
