---
interface Props {
  value: string;
  prefix?: string;
  counter: number;
  label: string;
}

const { value, prefix, counter, label } = Astro.props;
---

<div class="flex flex-col gap-2 bg-bg-elev p-8 transition-colors duration-fast hover:bg-surface">
  <p class="m-0 flex items-baseline gap-1 text-[clamp(40px,5vw,64px)] font-bold leading-none tracking-[-0.04em] tabular-nums text-fg">
    {prefix && <span aria-hidden="true">{prefix}</span>}
    <span data-counter={counter}>{value}</span>
  </p>
  <p class="m-0 text-sm font-medium text-fg-muted">{label}</p>
</div>
