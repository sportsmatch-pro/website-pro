---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalPageSection from '../../components/LegalPageSection.astro';
import { getTranslations } from '../../i18n/index';

const lang = 'ca' as const;
const t = getTranslations(lang);
---

<BaseLayout title={t['legal.notice.title']} description={t['legal.notice.desc']} lang={lang}>
  <LegalPageSection
    t={t}
    titleKey="legal.notice.title"
    descKey="legal.notice.desc"
    updatedKey="legal.notice.updated"
    contentKey="legal.notice.content"
  />
</BaseLayout>
