---
import { getTranslations, type Lang } from "../i18n/index";
import BaseButton from "./base/BaseButton.astro";
import IconAppStore from "./IconAppStore.astro";
import IconGooglePlay from "./IconGooglePlay.astro";
import StoreButtons from "./StoreButtons.astro";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const privacyHref =
  lang === "es"
    ? "/politica-de-privacidad"
    : lang === "ca"
      ? "/ca/politica-de-privacitat"
      : "/en/privacy-policy";
const termsHref =
  lang === "es" ? "/terminos" : lang === "ca" ? "/ca/termes" : "/en/terms";
const cookiesHref =
  lang === "es" ? "/cookies" : lang === "ca" ? "/ca/cookies" : "/en/cookies";
const gdprHref =
  lang === "es" ? "/gdpr" : lang === "ca" ? "/ca/gdpr" : "/en/gdpr";
const blogHref = lang === "es" ? "/blog/" : `/${lang}/blog/`;
const aboutHref =
  lang === "es" ? "/nosotros" : lang === "ca" ? "/ca/nosaltres" : "/en/about";
---

<footer
  class="pt-(--space-9) pb-(--space-7) border-t border-line bg-bg-elev"
  data-testid="main-footer"
>
  <div class="max-w-(--container) mx-auto px-[clamp(20px,4vw,48px)]">
    <!-- Grid -->
    <div
      class="grid grid-cols-[1.4fr_repeat(4,1fr)] gap-(--space-7) mb-(--space-8)
                max-[920px]:grid-cols-[1fr_1fr] max-[639px]:grid-cols-1"
    >
      <!-- Brand column — full-width at ≤ 920px -->
      <div class="max-[920px]:col-span-full">
        <a
          href={lang === "es" ? "/" : `/${lang}`}
          class="flex items-center shrink-0"
          aria-label="SportsMatch"
        >
          <img
            class="h-[26px] w-auto block dark:hidden"
            src="/assets/logo-dark.svg"
            alt="SportsMatch"
            width="111"
            height="26"
          />
          <img
            class="h-[26px] w-auto hidden dark:block"
            src="/assets/logo-light.svg"
            alt="SportsMatch"
            width="111"
            height="26"
          />
        </a>
        <p class="text-sm text-fg-muted leading-[1.6] mt-3 mb-5">
          {t["foot.tagline"]}
        </p>
        <div class="flex gap-2 flex-wrap">
          <StoreButtons t={t} />
        </div>
      </div>

      <!-- Producto -->
      <div class="hidden">
        <p
          class="text-[12px] font-semibold tracking-[0.12em] uppercase text-fg-subtle mb-4"
        >
          {t["foot.product"]}
        </p>
        <ul class="list-none p-0 m-0 flex flex-col gap-[10px]">
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="#">{t["foot.product.clubs"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="#">{t["foot.product.players"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="#">{t["foot.product.pros"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="#">{t["foot.product.sports"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="#">{t["foot.product.pricing"]}</a
            >
          </li>
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <p
          class="text-[12px] font-semibold tracking-[0.12em] uppercase text-fg-subtle mb-4"
        >
          {t["foot.company"]}
        </p>
        <ul class="list-none p-0 m-0 flex flex-col gap-[10px]">
          <li class="hidden">
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href={aboutHref}>{t["foot.company.about"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href={blogHref}>{t["foot.company.blog"]}</a
            >
          </li>
          <li class="hidden">
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="#">{t["foot.company.press"]}</a
            >
          </li>
          <li class="hidden">
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="#">{t["foot.company.contact"]}</a
            >
          </li>
        </ul>
      </div>

      <!-- Comunidad -->
      <div>
        <p
          class="text-[12px] font-semibold tracking-[0.12em] uppercase text-fg-subtle mb-4"
        >
          {t["foot.community"]}
        </p>
        <ul class="list-none p-0 m-0 flex flex-col gap-[10px]">
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="https://www.instagram.com/sports.match.pro/"
              target="_blank"
              rel="noopener noreferrer">{t["foot.community.instagram"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="https://www.tiktok.com/@sportsmatch_pro"
              target="_blank"
              rel="noopener noreferrer">{t["foot.community.tiktok"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="https://www.facebook.com/people/Sports-Match/100093952096508/"
              target="_blank"
              rel="noopener noreferrer">{t["foot.community.facebook"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href="https://www.linkedin.com/company/sportsmatchapp"
              target="_blank"
              rel="noopener noreferrer">{t["foot.community.linkedin"]}</a
            >
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <p
          class="text-[12px] font-semibold tracking-[0.12em] uppercase text-fg-subtle mb-4"
        >
          {t["foot.legal"]}
        </p>
        <ul class="list-none p-0 m-0 flex flex-col gap-[10px]">
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href={privacyHref}>{t["foot.privacy"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href={termsHref}>{t["foot.terms"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href={cookiesHref}>{t["foot.cookies"]}</a
            >
          </li>
          <li>
            <a
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg"
              href={gdprHref}>{t["foot.gdpr"]}</a
            >
          </li>
          <li>
            <button
              type="button"
              data-testid="cookie-preferences-reopen"
              data-cc="show-preferencesModal"
              class="text-sm text-fg-muted no-underline transition-colors duration-fast hover:text-fg bg-transparent border-0 p-0 cursor-pointer text-left"
              >{t["foot.cookies.manage"]}</button
            >
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="pt-8 border-t border-line flex items-center justify-between gap-4 flex-wrap text-[13px] text-fg-subtle"
    >
      <span>{t["foot.copy"]}</span>
      <div class="flex gap-5">
        <a
          class="no-underline transition-colors duration-fast hover:text-fg"
          href="mailto:info@sportsmatch.pro">info@sportsmatch.pro</a
        >
        <a
          class="no-underline transition-colors duration-fast hover:text-fg"
          href="tel:+34623757950">+34 623 75 79 50</a
        >
      </div>
    </div>
  </div>
</footer>
