---
import IconArrowRight from './IconArrowRight.astro';

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section class="duality-split">
  <!-- Lead (eyebrow + heading) -->
  <div class="duality-split__lead container">
    <span class="eyebrow">{t['duality.eyebrow']}</span>
    <h2 class="duality-split__heading">{t['duality.title']}</h2>
  </div>

  <!-- Stage -->
  <div class="duality-split__stage">
    <!-- Layer 1: copy + single bg image -->
    <div class="duality-split__stage_container container">
      <img class="duality-split__bg" src="/assets/duality-club.jpg" alt="" loading="lazy" />

      <!-- Left side: clubs/scouts -->
      <a class="duality-split__side duality-split__side--player" href="#" aria-label="Soy jugador o profesional">
        <div class="duality-split__copy">
          <span class="duality-split__kicker">{t['duality.club.tag']}</span>
          <h3 class="duality-split__title" set:html={t['duality.club.title']} />
          <p class="duality-split__lede">{t['duality.club.desc']}</p>
          <ul class="duality-split__bullets">
            <li>{t['duality.club.b1']}</li>
            <li>{t['duality.club.b2']}</li>
            <li>{t['duality.club.b3']}</li>
          </ul>
          <span class="duality-split__cta">
            <span>{t['duality.club.cta']}</span>
            <IconArrowRight />
          </span>
        </div>
      </a>

      <span class="duality-split__divider" aria-hidden="true"></span>

      <!-- Right side: players/pros -->
      <a class="duality-split__side duality-split__side--club" href="#" aria-label="Soy club o scouter">
        <div class="duality-split__copy">
          <span class="duality-split__kicker">{t['duality.player.tag']}</span>
          <h3 class="duality-split__title" set:html={t['duality.player.title']} />
          <p class="duality-split__lede">{t['duality.player.desc']}</p>
          <ul class="duality-split__bullets">
            <li>{t['duality.player.b1']}</li>
            <li>{t['duality.player.b2']}</li>
            <li>{t['duality.player.b3']}</li>
          </ul>
          <span class="duality-split__cta">
            <span>{t['duality.player.cta']}</span>
            <IconArrowRight />
          </span>
        </div>
      </a>
    </div>

    <!-- Layer 2: veil strips (20px tall) -->
    <div class="duality-split__stage_container">
      <a class="duality-split__side duality-split__side--player" href="#" aria-label="Soy jugador o profesional">
        <span class="duality-split__veil" aria-hidden="true"></span>
      </a>
      <span class="duality-split__divider" aria-hidden="true"></span>
      <a class="duality-split__side duality-split__side--club" href="#" aria-label="Soy club o scouter">
        <span class="duality-split__veil" aria-hidden="true"></span>
      </a>
    </div>
  </div>
</section>

<style>
  .duality-split {
    position: relative;
    padding-block: var(--density-section) 0;
    background: var(--bg-elev);
    border-block: 1px solid var(--line);
    overflow: hidden;
  }

  .duality-split__lead {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 56px;
    align-items: center;
    max-width: var(--container, 1280px);
    margin-left: auto;
    margin-right: auto;
    padding-inline: clamp(20px, 4vw, 48px);
  }

  .duality-split__heading {
    font-size: clamp(40px, 6vw, 80px);
    line-height: 0.96;
    letter-spacing: -0.035em;
    font-weight: 700;
    margin: 0;
    max-width: 18ch;
    text-wrap: balance;
    color: var(--fg);
  }

  /* Stage: two sides + divider */
  .duality-split__stage {
    background-color: #000;
  }

  .duality-split__stage_container {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: clamp(520px, 44vh, 720px);
    isolation: isolate;
    overflow: hidden;
  }

  .duality-split__stage_container + .duality-split__stage_container {
    height: 20px;
  }

  .duality-split__side {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    color: #fff;
    text-decoration: none;
    transition: flex var(--t-slow, 480ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1));
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
  }

  /* Left side (player) on top */
  .duality-split__side--player {
    z-index: 2;
  }

  /* Right side (club) overlaps left slightly */
  .duality-split__side--club {
    margin-left: -60px;
    z-index: 1;
  }

  /* Background image */
  .duality-split__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform var(--t-slow, 480ms) var(--ease-out, cubic-bezier(0.16, 1, 0.3, 1)), filter var(--t-slow, 480ms);
    filter: brightness(0.55) saturate(1.05);
  }

  .duality-split__side--player .duality-split__bg {
    object-position: 50% 35%;
  }

  .duality-split__side--club .duality-split__bg {
    object-position: 50% 30%;
  }

  .duality-split__side:hover .duality-split__bg {
    transform: scale(1.04);
    filter: brightness(0.7) saturate(1.15);
  }

  /* Veil: accent tint strips */
  .duality-split__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .duality-split__side--player .duality-split__veil {
    background: var(--brand-orange);
  }

  .duality-split__side--club .duality-split__veil {
    background: var(--brand-green);
  }

  /* Copy block */
  .duality-split__copy {
    position: relative;
    z-index: 3;
    padding: clamp(28px, 4vw, 56px);
    max-width: 570px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* Club copy: items flush-right, but text flows left */
  .duality-split__side--club .duality-split__copy {
    margin-left: auto;
    text-align: left;
    align-items: flex-end;
    max-width: 470px;
  }

  .duality-split__kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    align-self: flex-start;
    color: #fff;
  }

  .duality-split__side--club .duality-split__kicker {
    align-self: flex-end;
  }

  .duality-split__title {
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-weight: 700;
    margin: 0;
    color: #fff;
    text-wrap: balance;
  }

  .duality-split__side--club .duality-split__title {
    text-align: right;
  }

  :global(.duality-split__side--club .duality-split__title i) {
    color: var(--brand-green);
    font-style: italic;
  }

  :global(.duality-split__side--player .duality-split__title i) {
    color: var(--brand-orange);
    font-style: italic;
  }

  .duality-split__lede {
    color: rgba(255, 255, 255, 0.78);
    font-size: 15px;
    line-height: 1.55;
    margin: 0;
  }

  .duality-split__bullets {
    list-style: none;
    margin: 4px 0 6px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.85);
    width: 100%;
  }

  .duality-split__bullets li {
    padding-left: 18px;
    position: relative;
  }

  .duality-split__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand-orange);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.18);
  }

  .duality-split__side--club .duality-split__bullets li {
    padding-right: 0;
    padding-left: 18px;
  }

  .duality-split__side--club .duality-split__bullets li::before {
    left: 0;
    background: var(--brand-green);
    box-shadow: 0 0 0 3px rgba(1, 140, 41, 0.3);
  }

  /* CTA button */
  .duality-split__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
    padding: 12px 18px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.005em;
    align-self: flex-start;
    text-decoration: none;
    transition: transform var(--t-fast, 140ms) var(--ease-snap, cubic-bezier(0.4, 0, 0.2, 1)), background var(--t-fast, 140ms);
    color: #fff;
  }

  .duality-split__side--club .duality-split__cta {
    align-self: flex-end;
    background: var(--brand-green);
    color: #fff;
  }

  .duality-split__side--player .duality-split__cta {
    background: var(--brand-orange);
    color: #fff;
  }

  .duality-split__side:hover .duality-split__cta {
    transform: translateY(-1px);
  }

  :global(.duality-split__cta svg) {
    width: 16px;
    height: 16px;
    transition: transform var(--t-fast, 140ms);
  }

  .duality-split__side:hover :global(.duality-split__cta svg) {
    transform: translateX(4px);
  }

  /* Central divider */
  .duality-split__divider {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    display: grid;
    place-items: center;
  }

  .duality-split__divider::before {
    content: '';
    position: absolute;
    top: -10%;
    left: 50%;
    height: 130%;
    width: 30px;
    background: var(--bg-elev);
    transform: translateX(-50%) rotate(0deg);
    transform-origin: center;
  }

  /* Mobile: stack vertically */
  @media (max-width: 820px) {
    .duality-split__stage_container {
      grid-template-columns: 1fr;
      height: auto;
    }

    .duality-split__side {
      min-height: 420px;
      clip-path: none !important;
      margin: 0 !important;
    }

    .duality-split__side--club .duality-split__copy {
      margin-left: 0;
      text-align: left;
      align-items: flex-start;
    }

    .duality-split__side--club .duality-split__kicker {
      align-self: flex-start;
    }

    .duality-split__side--club .duality-split__cta {
      align-self: flex-start;
    }

    .duality-split__side--club .duality-split__bullets li {
      padding-left: 18px;
      padding-right: 0;
    }

    .duality-split__side--club .duality-split__bullets li::before {
      left: 0;
      right: auto;
    }

    .duality-split__divider {
      position: relative;
      inset: auto;
      height: 60px;
    }

    .duality-split__divider::before {
      height: 60px;
      transform: rotate(90deg);
      top: 0;
    }
  }
</style>
