---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalPageSection from '../../components/LegalPageSection.astro';
import { getTranslations } from '../../i18n/index';

const lang = 'ca' as const;
const t = getTranslations(lang);
---

<BaseLayout title={t['legal.privacy.title']} description={t['legal.privacy.desc']} lang={lang}>
  <LegalPageSection
    t={t}
    titleKey="legal.privacy.title"
    descKey="legal.privacy.desc"
    updatedKey="legal.privacy.updated"
    contentKey="legal.privacy.content"
  />
</BaseLayout>
