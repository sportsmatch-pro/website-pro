---
import { getTranslations, type Lang } from '../i18n/index';
import IconCaret from './IconCaret.astro';
import IconNavClubs from './IconNavClubs.astro';
import IconNavPlayers from './IconNavPlayers.astro';
import IconNavPros from './IconNavPros.astro';
import IconNavSports from './IconNavSports.astro';
import IconGlobe from './IconGlobe.astro';
import IconDownload from './IconDownload.astro';
import IconMoon from './IconMoon.astro';
import IconMenu from './IconMenu.astro';

export interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = getTranslations(lang);

// Language route map
const langRoutes: Record<Lang, string> = {
  es: '/',
  ca: '/ca',
  en: '/en',
};

// Current lang label
const langLabel = lang.toUpperCase();

// Language-specific blog/about paths
const blogHref = lang === 'es' ? '/blog' : `/${lang}/blog`;
const aboutHref = lang === 'es' ? '/nosotros' : lang === 'ca' ? '/ca/nosaltres' : '/en/about';
---

<header class="site-header" data-testid="main-header">
  <div class="site-header__inner">
    <!-- Logo -->
    <a href={langRoutes[lang]} class="site-logo" aria-label={t['nav.logo.aria']}>
      <img class="site-logo__img site-logo__img--dark" src="/logo-dark.svg" alt="SportsMatch" />
      <img class="site-logo__img site-logo__img--light" src="/logo-light.svg" alt="SportsMatch" />
    </a>

    <!-- Primary nav (desktop) -->
    <nav class="site-nav desktop-nav" aria-label="Principal">
      <!-- Producto dropdown -->
      <div class="dropdown">
        <button type="button" class="site-nav__item" data-dropdown-trigger aria-expanded="false" aria-haspopup="true">
          <span>{t['nav.product']}</span>
          <IconCaret />
        </button>
        <div class="dropdown__panel" role="menu">
          <a class="dropdown__item" href="#" role="menuitem">
            <span class="dropdown__icon">
              <IconNavClubs class="w-5 h-5" />
            </span>
            <div>
              <p class="dropdown__title">{t['nav.product.clubs']}</p>
              <p class="dropdown__desc">{t['nav.product.clubs.d']}</p>
            </div>
          </a>
          <a class="dropdown__item" href="#" role="menuitem">
            <span class="dropdown__icon">
              <IconNavPlayers class="w-5 h-5" />
            </span>
            <div>
              <p class="dropdown__title">{t['nav.product.players']}</p>
              <p class="dropdown__desc">{t['nav.product.players.d']}</p>
            </div>
          </a>
          <a class="dropdown__item" href="#" role="menuitem">
            <span class="dropdown__icon">
              <IconNavPros class="w-5 h-5" />
            </span>
            <div>
              <p class="dropdown__title">{t['nav.product.pros']}</p>
              <p class="dropdown__desc">{t['nav.product.pros.d']}</p>
            </div>
          </a>
          <a class="dropdown__item" href="#" role="menuitem">
            <span class="dropdown__icon">
              <IconNavSports class="w-5 h-5" />
            </span>
            <div>
              <p class="dropdown__title">{t['nav.product.sports']}</p>
              <p class="dropdown__desc">{t['nav.product.sports.d']}</p>
            </div>
          </a>
        </div>
      </div>

      <a class="site-nav__item" href={blogHref}>{t['nav.blog']}</a>
      <a class="site-nav__item" href={aboutHref}>{t['nav.about']}</a>
    </nav>

    <!-- Header actions -->
    <div class="header-actions">
      <!-- Language selector (desktop) -->
      <div class="lang-dropdown desktop-only" data-open="false">
        <button
          class="lang-dropdown__trigger"
          type="button"
          data-lang-trigger
          aria-haspopup="listbox"
          aria-expanded="false"
        >
          <IconGlobe class="w-3.5 h-3.5" />
          <span class="lang-dropdown__label">{langLabel}</span>
          <IconCaret class="w-2.5 h-2.5" />
        </button>
        <div class="lang-dropdown__menu" role="listbox">
          <a
            class="lang-dropdown__item"
            href="/"
            role="option"
            aria-current={lang === 'es' ? 'true' : 'false'}
          >
            <span>ES</span>
            <span class="lang-dropdown__name">{t['lang.es']}</span>
          </a>
          <a
            class="lang-dropdown__item"
            href="/ca"
            role="option"
            aria-current={lang === 'ca' ? 'true' : 'false'}
          >
            <span>CA</span>
            <span class="lang-dropdown__name">{t['lang.ca']}</span>
          </a>
          <a
            class="lang-dropdown__item"
            href="/en"
            role="option"
            aria-current={lang === 'en' ? 'true' : 'false'}
          >
            <span>EN</span>
            <span class="lang-dropdown__name">{t['lang.en']}</span>
          </a>
        </div>
      </div>

      <!-- Theme toggle -->
      <button
        class="icon-btn desktop-only"
        data-theme-toggle
        aria-label={t['theme.toggle']}
        type="button"
      >
        <IconMoon class="w-5 h-5" />
      </button>

      <!-- Sign in (desktop) -->
      <a class="btn btn--ghost desktop-only" href="#">{t['cta.signin']}</a>

      <!-- Download app (desktop) -->
      <a class="btn btn--primary desktop-only" href="#">
        <IconDownload class="w-3.5 h-3.5" />
        <span>{t['cta.download']}</span>
      </a>

      <!-- Mobile hamburger -->
      <button
        class="icon-btn mobile-only"
        type="button"
        data-mobile-toggle
        aria-expanded="false"
        aria-label={t['nav.open']}
      >
        <IconMenu class="w-5 h-5" />
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer" data-mobile-drawer data-open="false">
    <!-- Producto items flat -->
    <a class="site-nav__item" href="#">{t['nav.product.clubs']}</a>
    <a class="site-nav__item" href="#">{t['nav.product.players']}</a>
    <a class="site-nav__item" href="#">{t['nav.product.pros']}</a>
    <a class="site-nav__item" href="#">{t['nav.product.sports']}</a>
    <hr style="border-color: var(--line); margin: 4px 0;" />
    <a class="site-nav__item" href={blogHref}>{t['nav.blog']}</a>
    <a class="site-nav__item" href={aboutHref}>{t['nav.about']}</a>
    <hr style="border-color: var(--line); margin: 4px 0;" />
    <!-- Language links -->
    <a class="site-nav__item" href="/">ES — {t['lang.es']}</a>
    <a class="site-nav__item" href="/ca">CA — {t['lang.ca']}</a>
    <a class="site-nav__item" href="/en">EN — {t['lang.en']}</a>
    <hr style="border-color: var(--line); margin: 4px 0;" />
    <!-- Theme toggle in drawer -->
    <button class="site-nav__item" data-theme-toggle type="button" style="width:100%;text-align:left;background:none;border:none;cursor:pointer;">
      <IconMoon class="w-5 h-5" />
      <span>{t['theme.toggle']}</span>
    </button>
  </div>
</header>

<script>
  import { initThemeToggle } from '../scripts/theme';
  import { initDropdowns } from '../scripts/dropdown';

  document.addEventListener('DOMContentLoaded', () => {
    initThemeToggle();
    initDropdowns();
  });
</script>

<style>
  /* Desktop (≥1024px): show desktop nav, hide mobile elements */
  @media (min-width: 1024px) {
    .mobile-only {
      display: none !important;
    }
    .mobile-drawer {
      display: none !important;
    }
  }

  /* Mobile (<1024px): hide desktop nav and action items */
  @media (max-width: 1023px) {
    .desktop-nav {
      display: none !important;
    }
    .desktop-only {
      display: none !important;
    }
  }
</style>
