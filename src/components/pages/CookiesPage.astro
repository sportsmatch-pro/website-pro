  <li><strong>Accept cookies.</strong> This notice will not be displayed again when accessing any page on the portal during the current session.</li>
  <li><strong>Close.</strong> The notice is hidden on the current page.</li>
  <li><strong>Modify your settings.</strong> You can get more information about what cookies are, learn about the Cookies Policy of www.sportsmatch.pro and modify your browser settings.</li>
</ul>`,
      },
    ],
  },
};

const t = translations[currentLang as keyof typeof translations] || translations["es-ES"];
---

<div class="max-w-4xl mx-auto px-4 py-8 mt-16">
  <h1 class="text-4xl font-bold mb-8">{t.title}</h1>

  <div class="prose prose-lg max-w-none">
    {t.sections.map((section) => (
      <Fragment>
        <h2 class="text-2xl font-semibold mb-4 mt-8">{section.title}</h2>
        <div class="mb-6" set:html={section.content} />
      </Fragment>
    ))}
  </div>
</div>
