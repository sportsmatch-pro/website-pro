---
import BaseButton from './base/BaseButton.astro';
import BaseTitle from './base/BaseTitle.astro';
import BaseText from './base/BaseText.astro';
import IconArrowRight from './IconArrowRight.astro';
import SportCard from './SportCard.astro';

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;

type Sport = {
  key: string;
  label: string;
  image: string;
  size: 'xxl' | 'sm' | 'md';
  comingSoon?: boolean;
};

const sports: Sport[] = [
  { key: 'soccer',            label: 'Fútbol',           image: '/assets/sports/soccer.jpg',            size: 'xxl' },
  { key: 'basketball',        label: 'Básquet',           image: '/assets/sports/basketball.jpg',        size: 'sm' },
  { key: 'futsal',            label: 'Futsal',            image: '/assets/sports/futsal.jpg',            size: 'sm' },
  { key: 'rinkhockey',        label: 'Hockey Patines',    image: '/assets/sports/rinkhockey.jpg',        size: 'sm' },
  { key: 'volleyball',        label: 'Voleibol',          image: '/assets/sports/volleyball.jpg',        size: 'sm' },
  { key: 'handball',          label: 'Balonmano',         image: '/assets/sports/handball.jpg',          size: 'sm' },
  { key: 'baseball',          label: 'Béisbol',           image: '/assets/sports/baseball.jpg',          size: 'md', comingSoon: true },
  { key: 'american-football', label: 'Fútbol americano',  image: '/assets/sports/american-football.jpg', size: 'md', comingSoon: true },
];
---

<section class="py-(--density-section)">
  <div class="container">

    <!-- Header -->
    <div class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr] gap-8 items-end mb-14">
      <div>
        <span class="eyebrow">{t['sports.eyebrow']}</span>
        <BaseTitle tag="h2" size="7xl" balance class="mt-3">
          {t['sports.title']}
        </BaseTitle>
      </div>
      <BaseText size="xl" color="muted" class="max-w-[44ch]">
        {t['sports.sub']}
      </BaseText>
    </div>

    <!-- Bento grid -->
    <div class="sports-grid">
      {sports.map((sport) => (
        <SportCard
          label={sport.label}
          image={sport.image}
          hint={sport.comingSoon ? t['sports.soon'] : t['sports.live']}
          comingSoon={sport.comingSoon}
          size={sport.size}
        />
      ))}
    </div>

    <!-- CTA row -->
    <div class="flex flex-wrap items-center justify-center gap-4 mt-10">
      <BaseButton tag="a" variant="ghost" href="#" iconRight={IconArrowRight}>
        {t['sports.all']}
      </BaseButton>
      <span class="text-[13px] text-fg-muted">{t['sports.note']}</span>
    </div>

  </div>
</section>

<style>
  /* Grid container */
  .sports-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 200px;
    gap: 14px;
  }

  /* Card sizes — desktop (6 cols) */
  .sports-grid :global(.sport-card--xxl) { grid-column: span 4; grid-row: span 2; }
  .sports-grid :global(.sport-card--md)  { grid-column: span 3; grid-row: span 2; }
  .sports-grid :global(.sport-card--sm)  { grid-column: span 2; grid-row: span 1; }

  /* Tablet (4 cols) */
  @media (max-width: 1024px) {
    .sports-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 180px;
    }
    .sports-grid :global(.sport-card--xxl) { grid-column: span 4; grid-row: span 2; }
    .sports-grid :global(.sport-card--md)  { grid-column: span 2; grid-row: span 2; }
    .sports-grid :global(.sport-card--sm)  { grid-column: span 2; grid-row: span 1; }
  }

  /* Mobile (2 cols) — all cards stack uniformly */
  @media (max-width: 640px) {
    .sports-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 160px;
    }
    .sports-grid :global(.sport-card--xxl),
    .sports-grid :global(.sport-card--md),
    .sports-grid :global(.sport-card--sm) {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
</style>
