---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import DualitySplitSection from '../components/DualitySplitSection.astro';
import SportsGallerySection from '../components/SportsGallerySection.astro';
import { getTranslations } from '../i18n/index';

const lang = 'es' as const;
const t = getTranslations(lang);
---

<BaseLayout
  title={t['page.home.title'] ?? 'SportsMatch — Tu match deportivo, sin intermediarios'}
  description={t['page.home.desc'] ?? 'La plataforma que conecta jugadores, profesionales y clubes deportivos. Perfiles verificados, contacto directo, sin ruido.'}
  lang={lang}
>
  <HeroSection t={t} />
  <DualitySplitSection t={t} />
  <SportsGallerySection t={t} />
</BaseLayout>
