---
import { getTranslations, type Lang } from "../i18n/index";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<div
  class="fixed bottom-4 left-4 right-4 z-[90]
         hidden max-[720px]:flex items-center justify-between gap-3
         bg-fg text-bg
         py-3 pl-4 pr-3 rounded-lg shadow-(--shadow-lg)"
  role="complementary"
  aria-label="Download app"
>
  <div>
    <span class="text-[14px] font-semibold tracking-[-0.01em]"
      >{t["sticky.brand"]}</span
    >
    <span class="block text-[11px] opacity-70 mt-0.5"
      >{t["sticky.tagline"]}</span
    >
  </div>
  <a
    class="inline-flex items-center shrink-0 px-4 py-[10px] rounded-pill
           bg-brand-green text-white text-[13px] font-semibold no-underline whitespace-nowrap
           transition-colors duration-fast hover:bg-brand-green-hover"
    href="https://share.sportsmatch.pro">{t["cta.download.mobile"]}</a
  >
</div>
