---
import Layout from "../../../../../layouts/Layout.astro";
import BlogIndex from "../../../../../components/BlogIndex.astro";
import type { GetStaticPaths } from "astro";

const currentLang = "en";
const blogBasePath = "/en/blog";
const pageSize = 12;

export const getStaticPaths = (async ({ paginate }) => {
  try {
    const [articlesRes, sportsRes] = await Promise.all([
      fetch(
        `${import.meta.env.API_BASE_URL}articles?language=en&sortField=publishedAt&sortOrder=DESC`,
      ),
      fetch(`${import.meta.env.API_BASE_URL}sports`),
    ]);

    const posts = await articlesRes.json();
    const postsArray = Array.isArray(posts) ? posts : posts.items || [];
    const sports = await sportsRes.json();

    const paths = sports.flatMap((sport: { name: string }) => {
      const sportPosts = postsArray.filter((post: any) =>
        post.sports?.some((s: { name: string }) => s.name === sport.name),
      );

      if (sportPosts.length === 0) return [];

      return paginate(sportPosts, {
        params: { sport: sport.name },
        pageSize: 12,
      });
    });

    return paths;
  } catch {
    return [];
  }
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { sport } = Astro.params;

const sportTranslations: Record<string, string> = {
  soccer: "Soccer",
  basketball: "Basketball",
  handball: "Handball",
  volleyball: "Volleyball",
  futsal: "Futsal",
  rink_hockey: "Rink Hockey",
  coach: "Staff",
};

const sportName = sportTranslations[sport?.toLowerCase() || ""] || sport;
---

<Layout title={`Blog - ${sportName}`} currentLang={currentLang}>
  <BlogIndex
    currentLang={currentLang}
    blogBasePath={blogBasePath}
    posts={page.data}
    pagination={{
      currentPage: page.currentPage,
      lastPage: page.lastPage,
      url: {
        prev: page.url.prev,
        next: page.url.next,
      },
    }}
    activeSport={sport}
  />
</Layout>
