---
import IconArrowRight from './IconArrowRight.astro';

type Size = 'xxl' | 'sm' | 'md';

interface Props {
  label: string;
  image: string;
  hint: string;
  comingSoon?: boolean;
  size?: Size;
  href?: string;
}

const {
  label,
  image,
  hint,
  comingSoon = false,
  size = 'sm',
  href = '#',
} = Astro.props;

const sizeClass: Record<Size, string> = {
  xxl: 'sport-card--xxl',
  md:  'sport-card--md',
  sm:  'sport-card--sm',
};
---

<a
  href={href}
  class:list={[
    'sport-card group relative block rounded-xl overflow-hidden bg-surface-2 isolate no-underline',
    'transition-transform duration-300 ease-out hover:-translate-y-1',
    sizeClass[size],
  ]}
>
  <!-- Photo -->
  <img
    src={image}
    alt=""
    loading="lazy"
    class="absolute inset-0 w-full h-full object-cover saturate-[1.05] brightness-[0.85]
           transition-[transform,filter] duration-500 ease-out
           group-hover:scale-105 group-hover:saturate-[1.15] group-hover:brightness-100"
  />

  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 z-[1]"
    style="background: linear-gradient(180deg, transparent 30%, rgba(0,0,0,0.85) 100%)"
    aria-hidden="true"
  ></div>

  <!-- Body -->
  <div class="absolute inset-x-0 bottom-0 z-[2] flex items-end justify-between gap-3 p-5 text-white">
    <div>
      <!-- Badge -->
      <p class="flex items-center gap-1.5 mb-1.5 text-[11px] font-semibold uppercase tracking-[0.06em] text-white/70">
        <span
          class:list={[
            'w-1.5 h-1.5 rounded-full shrink-0',
            comingSoon
              ? 'bg-[#f9c64a] shadow-[0_0_0_3px_rgba(249,198,74,0.3)]'
              : 'bg-brand-green shadow-[0_0_0_3px_rgba(1,140,41,0.3)]',
          ]}
          aria-hidden="true"
        ></span>
        {hint}
      </p>
      <!-- Sport name -->
      <h3 class="m-0 text-[22px] font-bold leading-none tracking-[-0.02em]">{label}</h3>
    </div>

    <!-- Arrow button — reveals on hover -->
    <span
      aria-hidden="true"
      class="flex-none w-10 h-10 rounded-full grid place-items-center
             bg-white/10 border border-white/20 backdrop-blur-sm
             opacity-0 translate-x-2 -translate-y-2
             transition-[opacity,transform] duration-150 ease-out
             group-hover:opacity-100 group-hover:translate-x-0 group-hover:translate-y-0"
    >
      <IconArrowRight class="w-4 h-4 text-white" />
    </span>
  </div>
</a>
